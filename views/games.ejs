<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head.ejs') %>
<body>
    <%- include('./partials/header.ejs') %>
    <main class="all-games">
        <div class="show-all-games">
            <% for(let i = 0; i < games.length; i+=1) { %>
                <div class="game" id=<%=`${id[i]}`%>>
                    <a href=<%=`/games/${id[i]}`%>>
                        <div class="cover-title"><%= games[i] %></div>
                        <img class="image-cover" src=<%= images[i]%> onerror='this.style.opacity = "0.0"' alt='game cover' srcset="">
                    </a>
                </div>
            <%}%>
            <div class="game new" id='0'>
                <a href='/new'>
                    <img class="image-add" src='../icons/add.svg' alt="add cover" srcset="">
                </a>
            </div>
        </div>
    </main>
    <%- include('./partials/footer.ejs') %>
</body>
</html>